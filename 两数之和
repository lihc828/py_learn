class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        seen = {}  # 记录：数字 → 下标

        for i, num in enumerate(nums):
            need = target - num  # 我还需要谁

            if need in seen:
                # 之前见过 need，直接返回两个下标
                return [seen[need], i]

            # 没见过，就把当前数字记下来
            seen[num] = i

        return []  # 理论上不会到这里
