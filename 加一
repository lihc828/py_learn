class Solution:
    def plusOne(self, digits: List[int]) -> List[int]:
        # 从右往左遍历（个位 → 十位 → 百位 ...）
        for i in range(len(digits) - 1, -1, -1):
            if digits[i] == 9:
                digits[i] = 0   # 当前位变 0，继续向前进位
            else:
                digits[i] += 1  # 非 9，直接 +1，结束
                return digits

        # 如果所有位都是 9，比如 [9,9,9]
        digits.insert(0, 1)
        return digits
